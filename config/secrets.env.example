# ─────────────────────────────────────────────────────────────────────
# secrets.env — EXAMPLE (copy to secrets.env and fill real values)
# NEVER COMMIT secrets.env. It is in .gitignore.
# ─────────────────────────────────────────────────────────────────────

# Kalshi (get from: https://kalshi.com/profile/api-access)
KALSHI_API_KEY_ID=
KALSHI_PRIVATE_KEY_PATH=config/kalshi_private.pem

# Polymarket (your EOA or proxy wallet private key)
POLY_PRIVATE_KEY=
POLY_PROXY_WALLET=

# Anthropic (optional for dev; required if you want fresh LLM verification)
ANTHROPIC_API_KEY=

# Telegram bot (optional; create via @BotFather on Telegram)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# PostgreSQL (Phase 5 only — leave blank for dev)
POSTGRES_URL=

