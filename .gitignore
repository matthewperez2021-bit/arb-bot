# Secrets — NEVER commit these
config/secrets.env
config/Arg-bot.txt
*.pem
*.key
*.p8

# Database — track arb_positions.db so trade history syncs across machines.
# Ignore SQLite sidecar/WAL files and the local backup.
data/*.db-shm
data/*.db-wal
data/*.sqlite
data/arb_positions.db.bak

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/
.env

# Snapshots (large files)
data/snapshots/

# Match cache
data/match_cache.json

# Harvester runtime caches + per-day snapshots (runtime only, not source)
data/harvester_cache.json
data/historical_odds/
data/player_prop_cache.json
data/calibration_*.csv

# Logs
*.log
logs/

# OS
.DS_Store
Thumbs.db
.fuse_hidden*
